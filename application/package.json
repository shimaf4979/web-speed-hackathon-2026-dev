{
  "name": "@web-speed-hackathon-2026/application",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @web-speed-hackathon-2026/client build && pnpm --filter @web-speed-hackathon-2026/server generate:terms-html",
    "start": "pnpm --filter @web-speed-hackathon-2026/server start",
    "analyze:lighthouse": "node ./scripts/run-lighthouse.mjs --mode scoring --device desktop",
    "analyze:lighthouse:mobile": "node ./scripts/run-lighthouse.mjs --mode cli --device mobile",
    "analyze:lighthouse:desktop": "node ./scripts/run-lighthouse.mjs --mode scoring --device desktop",
    "generate:image-thumbnails": "node ./scripts/generate-image-thumbnails.mjs --apply",
    "generate:image-thumbnails:dry-run": "node ./scripts/generate-image-thumbnails.mjs",
    "generate:profile-image-variants": "node ./scripts/generate-profile-image-variants.mjs --apply",
    "generate:profile-image-variants:dry-run": "node ./scripts/generate-profile-image-variants.mjs",
    "compress:public-assets": "node ./scripts/compress-public-assets.mjs --apply",
    "compress:public-assets:dry-run": "node ./scripts/compress-public-assets.mjs",
    "generate:avif-variants": "node ./scripts/generate-avif-variants.mjs --apply",
    "generate:avif-variants:dry-run": "node ./scripts/generate-avif-variants.mjs",
    "recompress:public-media": "node ./scripts/recompress-public-media.mjs --apply",
    "recompress:public-media:dry-run": "node ./scripts/recompress-public-media.mjs",
    "typecheck": "pnpm run --recursive typecheck",
    "format": "pnpm run format:oxlint && pnpm run format:oxfmt",
    "format:oxlint": "oxlint --fix",
    "format:oxfmt": "oxfmt"
  },
  "devDependencies": {
    "ffmpeg-static": "5.3.0",
    "lighthouse": "12.8.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.43.0",
    "sharp": "0.34.5"
  },
  "engines": {
    "node": "24.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "bcrypt",
      "esbuild",
      "sqlite3",
      "negaposi-analyzer-ja",
      "sharp",
      "ffmpeg-static"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
